# 複製此檔為 secrets.toml 並填入實際連線資訊
# cp .streamlit/secrets.toml.example .streamlit/secrets.toml

OPENAI_API_KEY = "sk-..."
SUPABASE_URL   = "https://xxx.supabase.co"
SUPABASE_KEY   = "eyJ..."

[oracle]
user     = "your_db_user"
password = "your_db_password"
dsn      = "hostname:1521/service_name"
# thin mode（預設）不需要安裝 Oracle Instant Client
# 若需要 thick mode，請在 app.py 呼叫 oracledb.init_oracle_client()
